# OpenAI API key (required for JD analysis, message generation, weekly review)
OPENAI_API_KEY=your-openai-api-key-here

# JWT signing secret — generate a random 32+ character string
JOBOPS_JWT_SECRET=change-me-to-a-random-64-char-secret-before-using-in-production

# PostgreSQL (defaults match docker-compose.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/jobops
SPRING_DATASOURCE_USERNAME=jobops
SPRING_DATASOURCE_PASSWORD=jobops

# Local file storage root for CV uploads
JOBOPS_STORAGE_ROOT=.jobops/storage
